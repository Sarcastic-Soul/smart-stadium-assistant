# Smart Stadium Assistant – Backend Environment
# Copy to .env and fill in values

# LLM Provider (Optional – falls back to simulated response if missing)
GROQ_API_KEY=your_groq_api_key_here

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info

# CORS
FRONTEND_ORIGIN=http://localhost:5173
