# Smart Stadium Assistant – Backend Environment
# Copy to .env and fill in values

# LLM Provider
CLONEMODEL_API_KEY=your_anthropic_api_key_here

# GCP (for Secret Manager – used in production)
GCP_PROJECT_ID=promptwars-493516
GCP_SECRET_NAME=CLONEMODEL_API_KEY

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Database (optional)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stadium
